install -vDm755 bin/skopeo "$INSTALL_ROOT/usr/bin/skopeo" &&
install -vDm644 default-policy.json "$INSTALL_ROOT/etc/containers/policy.json" &&
install -vDm644 default.yaml "$INSTALL_ROOT/etc/containers/registries.d/default.yaml" &&
if [ -e docs/skopeo.1 ]; then
  install -vDm644 docs/*.1 -t "$INSTALL_ROOT/usr/share/man/man1/"
fi
