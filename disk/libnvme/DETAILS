         VERSION=1.16.2
     SOURCE_HASH=sha512:e3a4b6d4906e7dc5f894042adc6490bc7e71bf096d39f216c8c742bc5c527a701a87cb3ee8eea305fa557d1b312513c3394f7d6030000e320a2d668c53215fb5
           SOURCE=${SPELL}-${VERSION}.tar.gz
