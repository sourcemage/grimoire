           SPELL=drumstick
         VERSION=2.11.0
     SOURCE_HASH=sha512:1a49c31fb98093097b18beeb0f506a859247c9facfd6bb822e151dc6cc5467d74c3fa15d8c3860e90f289fd8b15f2489e8eb55561d3d79a8c9deeb9c0c5b69f4
          SOURCE=$SPELL-$VERSION.tar.bz2
   SOURCE_URL[0]=https://sourceforge.net/projects/drumstick/files/$SOURCE
SOURCE_DIRECTORY=$BUILD_DIRECTORY/$SPELL-$VERSION
        WEB_SITE=https://sourceforge.net/p/drumstick
      LICENSE[0]=GPL
         ENTERED=
        KEYWORDS="qt5 multimedia"
           SHORT=
cat << EOF
Drumstick is a set of MIDI libraries using C++/Qt5 idioms and style. Includes 
a C++ wrapper around the ALSA library sequencer interface: ALSA sequencer 
provides software support for MIDI technology on Linux. A complementary 
library provides classes for processing SMF (Standard MIDI files: .MID/.KAR), 
Cakewalk (.WRK), and Overture (.OVE) file formats
EOF

