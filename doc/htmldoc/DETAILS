           SPELL=htmldoc
         VERSION=1.9.23
     SOURCE_HASH=sha512:8adfebf2a2dbb2495639e9806cf0e5aa81c8b04ab09b3fff7f3f48745bc321e95f7af9b6bf36568b8c7c22c4f41fd04040475a70a7aafbb332330361d3014f52
  SECURITY_PATCH=1
          SOURCE=$SPELL-$VERSION-source.tar.gz
SOURCE_DIRECTORY="$BUILD_DIRECTORY/$SPELL-$VERSION"
        WEB_SITE=https://www.msweet.org/htmldoc
      SOURCE_URL=https://github.com/michaelrsweet/htmldoc/releases/download/v$VERSION/$SOURCE
         ENTERED=20041219
      LICENSE[0]=GPL
        KEYWORDS="pdf postscript html doc"
           SHORT="Converts HTML files to PDF or PostScript"
cat << EOF
htmldoc
* Converts HTML files to PDF or PostScript
* Generates a table-of-contents for books
* Generates indexed HTML files
* Generates files on-the-fly for web applications, from the
  command-line for batch jobs, or from a GUI for interactive work
* Runs on most UNIX/Linux operating systems as well as MacOS X
  and Windows
* Provides a command-line interface for batch and WWW applications
* Provides a graphical interface for interactive work
EOF
