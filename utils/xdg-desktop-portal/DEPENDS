. "${GRIMOIRE}/MESON_DEPENDS" &&

depends bubblewrap  &&
depends glib2       &&
depends gst-plugins-base-1.0 &&
depends json-glib   &&
depends fuse3       &&
depends gdk-pixbuf2 &&
depends PKG-CONFIG  &&

optional_depends geoclue                                                \
                 'geoclue=enabled'                                      \
                 'geoclue=disabled'                                     \
                 'Enable Geoclue support? (Needed for location portal)' &&

optional_depends systemd                                                \
                 'systemd=enabled'                                      \
                 'systemd=disabled'                                     \
                 'Enable systemd support?'                              &&

optional_depends sphinx                                                 \
                 'documentation=enabled'                                \
                 'documentation=disabled'                               \
                 'Build documentation?'                                 &&
if is_depends_enabled "$SPELL" sphinx; then
  depends flatpak
fi &&
optional_depends umockdev         \
                 'tests=enabled'  \
                 'tests=disabled' \
                 'for tests' &&

suggest_depends xdg-desktop-portal-gtk  "" "" "Gtk portal backend"               &&
suggest_depends xdg-desktop-portal-kde  "" "" "Kde portal backend"               &&
suggest_depends xdg-desktop-portal-lxqt "" "" "LxQt portal backend"              &&
suggest_depends xdg-desktop-portal-wlr  "" "" "wlroots portal backend (wayland)"
